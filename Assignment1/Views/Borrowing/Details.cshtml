@model Assignment1.Models.Borrowing
@{
    ViewData["Title"] = "Borrowing Details";
}

<h1>Borrowing Details</h1>
<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Book</dt>
            <dd class="col-sm-9">@ViewBag.BookTitle</dd>
            <dt class="col-sm-3">Reader</dt>
            <dd class="col-sm-9">@ViewBag.ReaderName</dd>
            <dt class="col-sm-3">Borrow Date</dt>
            <dd class="col-sm-9">@Model.BorrowDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Return Date</dt>
            <dd class="col-sm-9">@Model.ReturnDate?.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Overdue Charge</dt>
            <dd class="col-sm-9">$@Model.OverdueCharge.ToString("F2")</dd>
        </dl>
    </div>
</div>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</p>
