@model Assignment1.Models.Borrowing
@{
    ViewData["Title"] = "Edit Borrowing";
    var books = ViewBag.Books as IEnumerable<Assignment1.Models.Book>;
    var readers = ViewBag.Readers as IEnumerable<Assignment1.Models.Reader>;
}

<h1>Edit Borrowing</h1>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label class="form-label">Book</label>
        <select asp-for="BookId" class="form-control">
            @foreach (var book in books)
            {
                <option value="@book.Id">@book.Title</option>
            }
        </select>
        <span asp-validation-for="BookId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Reader</label>
        <select asp-for="ReaderId" class="form-control">
            @foreach (var reader in readers)
            {
                <option value="@reader.Id">@reader.Name</option>
            }
        </select>
        <span asp-validation-for="ReaderId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Borrow Date</label>
        <input asp-for="BorrowDate" class="form-control" type="date" />
        <span asp-validation-for="BorrowDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Due Date</label>
        <input asp-for="DueDate" class="form-control" type="date" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Return Date</label>
        <input asp-for="ReturnDate" class="form-control" type="date" />
    </div>
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="Status" class="form-control">
            <option value="Active">Active</option>
            <option value="Returned">Returned</option>
            <option value="Overdue">Overdue</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
