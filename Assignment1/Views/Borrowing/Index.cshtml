@model IEnumerable<Assignment1.Models.Borrowing>
@{
    ViewData["Title"] = "Borrowings";
    var statusList = ViewBag.StatusList as List<string>;
    var searchString = ViewBag.SearchString as string;
    var selectedStatus = ViewBag.SelectedStatus as string;
    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;
}

<h1>Borrowings</h1>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input type="text" name="searchString" value="@searchString" class="form-control" placeholder="Search book or reader" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Status</option>
                    @if (statusList != null)
                    {
                        @foreach (var s in statusList)
                        {
                            <option value="@s" selected="@(selectedStatus == s)">@s</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Start Date</label>
                <input type="date" name="startDate" value="@startDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">End Date</label>
                <input type="date" name="endDate" value="@endDate" class="form-control" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filter</button>
                <a asp-action="Index" class="btn btn-secondary me-2">Clear</a>
                <a asp-action="Create" class="btn btn-success">New</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No borrowings found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Book</th>
                <th>Reader</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Return Date</th>
                <th>Status</th>
                <th>Charge</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var borrowing in Model)
            {
                <tr>
                    <td><strong>@borrowing.Book?.Title</strong></td>
                    <td>@borrowing.Reader?.Name</td>
                    <td>@borrowing.BorrowDate.ToString("yyyy-MM-dd")</td>
                    <td class="@(borrowing.Status == "Overdue" ? "text-danger fw-bold" : "")">@borrowing.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>@borrowing.ReturnDate?.ToString("yyyy-MM-dd")</td>
                    <td>
                        @{
                            var statusBadge = borrowing.Status switch
                            {
                                "Active" => "bg-primary",
                                "Returned" => "bg-success",
                                "Overdue" => "bg-danger",
                                "Cancelled" => "bg-secondary",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @statusBadge">@borrowing.Status</span>
                    </td>
                    <td class="@(borrowing.OverdueCharge > 0 ? "text-danger fw-bold" : "")">
                        $@borrowing.OverdueCharge.ToString("F2")
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@borrowing.Id" class="btn btn-info btn-sm">View</a>
                        @if (borrowing.Status == "Active")
                        {
                            <a asp-action="Return" asp-route-id="@borrowing.Id" class="btn btn-success btn-sm">Return</a>
                        }
                        <a asp-action="Edit" asp-route-id="@borrowing.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@borrowing.Id" class="btn btn-danger btn-sm">Cancel</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
