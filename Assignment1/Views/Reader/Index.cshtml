@model IEnumerable<Assignment1.Models.Reader>
@{
    ViewData["Title"] = "Readers";
}

<h1>Readers</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Add New Reader</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Membership Type</th>
            <th>Registered Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reader in Model)
        {
            <tr>
                <td>@reader.Name</td>
                <td>@reader.Email</td>
                <td>@reader.Phone</td>
                <td><span class="badge bg-info">@reader.MembershipType</span></td>
                <td>@reader.RegisteredDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@reader.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@reader.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@reader.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
